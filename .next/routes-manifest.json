{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/api/join/[joinCode]",
      "regex": "^/api/join/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPjoinCode": "nxtPjoinCode"
      },
      "namedRegex": "^/api/join/(?<nxtPjoinCode>[^/]+?)(?:/)?$"
    },
    {
      "page": "/api/quizzes/[id]",
