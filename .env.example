# Public app URL used for QR codes and participant links.
NEXT_PUBLIC_APP_URL="https://fahrduell.example.com"

# Server-side base URL used for redirects and absolute server URLs.
APP_URL="https://fahrduell.example.com"

# Database.
DATABASE_URL="postgresql://fahrduell:fahrduell@localhost:5432/fahrduell?schema=public"

# Auth.
AUTH_SECRET="replace-with-long-random-secret"
ALLOW_DEMO_LOGIN="false"
DEMO_EMAIL="demo@fahrduell.local"
DEMO_PASSWORD="fahrduell"

# Realtime / Socket.IO.
SOCKET_CORS_ORIGIN="https://fahrduell.example.com"
REDIS_URL="redis://localhost:6379"

# Runtime.
NODE_ENV="production"
PORT="3000"

# Optional initial admin seed.
INITIAL_ADMIN_EMAIL="admin@fahrduell.de"
INITIAL_ADMIN_PASSWORD="change-me-before-production"
INITIAL_ADMIN_NAME="Fahrduell Admin"
